{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "lib": [
      "DOM",
      "ES2019"
    ]
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "tests/**",
    "node_modules"
  ]
}
