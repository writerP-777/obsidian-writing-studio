{
  "name": "obsidian-writing-studio",
  "version": "2.1.0",
  "description": "Obsidian Writing Studio Plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "keywords": [
    "obsidian",
    "writing",
    "focus",
    "productivity"
  ],
  "author": "Don Pucik",
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
