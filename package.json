{
  "name": "obsidian-writing-studio",
  "version": "2.2.3",
  "description": "Obsidian Writing Studio Plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "bump": "node scripts/bump.js",
    "test": "jest",
    "lint": "node node_modules/eslint-plugin-obsidianmd/node_modules/eslint/bin/eslint.js --max-warnings 0 main.ts src/ modals/",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "fetch:guidelines": "bash scripts/fetch-plugin-guidelines.sh",
    "check:scorecard": "bash scripts/scorecard-check.sh"
  },
  "overrides": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6"
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "esbuild": "0.28.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.11",
    "tslib": "2.8.1",
    "typescript": "6.0.3"
  },
  "keywords": [
    "obsidian",
    "writing",
    "focus",
    "productivity"
  ],
  "author": "Don Pucik",
  "license": "MIT",
  "dependencies": {
    "fflate": "^0.8.3",
    "i18next": "^26.3.0"
  }
}
